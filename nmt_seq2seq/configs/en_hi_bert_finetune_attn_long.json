{
  "experiment_name": "en_hi_bert_finetune_attn_long",
  "output_dir": "outputs/en_hi_bert_finetune_attn_long",
  "data": {
    "train_path": "data/translation/Hindi_train.csv",
    "dev_path": "data/translation/Hindi_dev.csv",
    "test_path": "data/translation/Hindi_public_test.csv",
    "source_column": "source",
    "target_column": "translated",
    "cleanup": {
      "strip_translate_prompt": true,
      "normalize_whitespace": true,
      "lowercase_source": false,
      "lowercase_target": false
    }
  },
  "source": {
    "type": "bert",
    "max_length": 160,
    "lowercase": false
  },
  "target": {
    "max_length": 96,
    "vocab_size": 5000
  },
  "model": {
    "bert_model_name": "bert-base-cased",
    "freeze_encoder": false,
    "use_attention": true,
    "decoder_hidden_size": 512,
    "target_embedding_dim": 256,
    "dropout": 0.2
  },
  "train": {
    "batch_size": 24,
    "epochs": 40,
    "learning_rate": 0.001,
    "encoder_learning_rate": 2e-05,
    "checkpoint_metric": "bleu",
    "teacher_forcing": {
      "type": "constant",
      "value": 0.6,
      "k": 8
    },
    "eval_beam_size": 1
  },
  "evaluation": {
    "beam_sizes": [1, 5, 10, 20],
    "max_decode_steps": 96
  }
}
